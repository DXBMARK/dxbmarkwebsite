# Environmental variables template for DXBMARK LLC website
# Copy this file to .env or .env.local and configure variables

# Core
NEXT_PUBLIC_SITE_URL=https://www.dxbmark.com

# Analytics
NEXT_PUBLIC_GA_ID=

# Zoho Integrations
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=

# Database Connectivity (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dxbmark_db

# Stripe Settings
STRIPE_RESTRICTED_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Upstash QStash
QSTASH_TOKEN=qstash_token_placeholder
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Sentry
SENTRY_DSN=https://placeholder@sentry.io/placeholder
SENTRY_TRACES_SAMPLE_RATE=0.1

# Modes
WEBHOOK_PROCESSING_MODE=log_only

